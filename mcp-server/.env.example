# Environment configuration for MCP server

# Retrieval Provider Type
# Options: simple, embeddings, full-rag
# - simple: Fast keyword-based search (no AI models needed)
# - embeddings: Vector similarity search using llama.cpp embeddings
# - full-rag: Embeddings + LLM response generation
RETRIEVAL_PROVIDER=simple

# Embedding Model Path (for 'embeddings' and 'full-rag' providers)
# Download embedding models from: https://huggingface.co/models
# Example: nomic-embed-text, all-MiniLM-L6-v2
# EMBEDDING_MODEL_PATH=./models/nomic-embed-text-v1.5.Q8_0.gguf

# LLM Model Path (for 'full-rag' provider only)
# Download LLMs from: https://huggingface.co/models
# Example: llama-3.2-1b-instruct, mistral-7b-instruct
# LLM_MODEL_PATH=./models/llama-3.2-1b-instruct-q4_0.gguf

# LLM Generation Parameters
# LLM_CONTEXT_SIZE=4096
# LLM_THREADS=4
# LLM_MAX_TOKENS=512
# LLM_TEMPERATURE=0.7
